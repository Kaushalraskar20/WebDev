<!DOCTYPE html>
<html>
<head>
  <title>Attendance</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-warning px-3">
  <span class="navbar-brand">Attendance</span>
  <a href="/dashboard" class="btn btn-dark">Back</a>
</nav>

<div class="container mt-4">
  <h3>Mark Attendance</h3>

  <img src="/images/attendance.jpg" class="img-fluid rounded mb-3" width="300">

  <form method="POST" class="row g-2 mb-4">
    <div class="col-md-3">
      <input name="student" class="form-control" placeholder="Student" required>
    </div>
    <div class="col-md-3">
      <input name="subject" class="form-control" placeholder="Subject" required>
    </div>
    <div class="col-md-3">
      <select name="status" class="form-select">
        <option>Present</option>
        <option>Absent</option>
      </select>
    </div>
    <div class="col-md-3">
      <button class="btn btn-warning w-100">Submit</button>
    </div>
  </form>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Student</th>
        <th>Subject</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(a => { %>
        <tr>
          <td><%= a.student %></td>
          <td><%= a.subject %></td>
          <td><%= a.status %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
