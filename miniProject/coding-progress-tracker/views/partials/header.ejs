<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Coding Progress Tracker</title>
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet"/>
  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    * { font-family: 'Space Grotesk', sans-serif; }

    body { background-color: #0f1117; color: #e2e8f0; min-height: 100vh; }

    .navbar {
      background: #1a1d27 !important;
      border-bottom: 1px solid #2d3148;
    }
    .navbar-brand {
      font-weight: 700;
      font-size: 1.2rem;
      color: #7c6af7 !important;
    }
    .nav-link { color: #94a3b8 !important; }
    .nav-link:hover { color: #7c6af7 !important; }

    .card {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 12px;
    }
    .card-title { color: #e2e8f0; font-weight: 600; }

    .btn-primary {
      background: #7c6af7;
      border-color: #7c6af7;
    }
    .btn-primary:hover { background: #6655e8; border-color: #6655e8; }

    .btn-outline-primary {
      color: #7c6af7;
      border-color: #7c6af7;
    }
    .btn-outline-primary:hover {
      background: #7c6af7;
      color: #fff;
    }

    .form-control, .form-select {
      background: #0f1117;
      border: 1px solid #2d3148;
      color: #e2e8f0;
      border-radius: 8px;
    }
    .form-control:focus, .form-select:focus {
      background: #0f1117;
      color: #e2e8f0;
      border-color: #7c6af7;
      box-shadow: 0 0 0 0.2rem rgba(124, 106, 247, 0.2);
    }
    .form-control::placeholder { color: #4a5568; }

    .badge-platform {
      font-size: 0.75rem;
      padding: 4px 10px;
      border-radius: 20px;
      font-weight: 500;
    }
    .platform-LeetCode     { background: #ffa11620; color: #ffa116; border: 1px solid #ffa11640; }
    .platform-CodeChef     { background: #5b4a2820; color: #c8a96e; border: 1px solid #c8a96e40; }
    .platform-HackerRank   { background: #00ea6420; color: #00ea64; border: 1px solid #00ea6440; }
    .platform-Codeforces   { background: #3b82f620; color: #60a5fa; border: 1px solid #3b82f640; }
    .platform-GeeksForGeeks{ background: #22c55e20; color: #4ade80; border: 1px solid #4ade8040; }

    .sheet-card {
      transition: transform 0.2s, border-color 0.2s;
      cursor: pointer;
    }
    .sheet-card:hover {
      transform: translateY(-3px);
      border-color: #7c6af7 !important;
    }

    .page-header {
      padding: 2rem 0 1rem;
      border-bottom: 1px solid #2d3148;
      margin-bottom: 2rem;
    }
    .page-header h2 { font-weight: 700; color: #e2e8f0; }
    .page-header p  { color: #64748b; margin: 0; }

    .progress-table th { color: #7c6af7; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .progress-table td { color: #cbd5e1; vertical-align: middle; }
    .table { --bs-table-bg: transparent; --bs-table-border-color: #2d3148; }

    .auth-card { max-width: 440px; margin: 5vh auto; }
    .auth-logo { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .auth-title { font-size: 1.6rem; font-weight: 700; }

    .solved-badge {
      background: #7c6af720;
      color: #7c6af7;
      border: 1px solid #7c6af740;
      border-radius: 8px;
      padding: 2px 10px;
      font-weight: 600;
    }
    .empty-state { text-align: center; padding: 3rem; color: #4a5568; }
    .empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; }
  </style>
</head>
<body>
